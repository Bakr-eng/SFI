<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="SFI.View.StudentInfoPage"
             Title="StudentInfoPage">
    <VerticalStackLayout>

        <Label
            Text="elevInfo"
            FontSize="30"
            HorizontalOptions="Center" 
        />

        <Label Text="Namn:" FontAttributes="Bold"/>
        <Label x:Name="NameLabel"/>

        <Label Text="Email:" FontAttributes="Bold" Margin="0,10,0,0"/>
        <Label x:Name="EmailLabel"/>

        <Label Text="KlassId:" FontAttributes="Bold" Margin="0,10,0,0"/>
        <Label x:Name="KlassIdLabel"/>
        
        
    </VerticalStackLayout>
</ContentPage>
<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="SFI.MainPage">

    <ScrollView>
        <VerticalStackLayout>

            <Label
                Text="VälKommen till SFI" 
                TextColor="Cyan"
                HorizontalTextAlignment="Center"
                VerticalTextAlignment="Center"
                Margin="0,40"
                />

           



            <Entry
                x:Name="email"
                Placeholder="användare namn"
                BackgroundColor="BlanchedAlmond"
                TextColor="Black"
                Margin="0,10"
                />

            <Entry
                x:Name="Password"
                IsPassword="True"
                Placeholder="lösenord"
                BackgroundColor="BlanchedAlmond"
                TextColor="Black"
                />

           

            <Button
                Text="loga in"
                Margin="70,50"
                Clicked="OnLogInClicked"
                />
            
            





        </VerticalStackLayout>
    </ScrollView>

</ContentPage>

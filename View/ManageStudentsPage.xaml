<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="SFI.View.ManageStudentsPage"
             Title="ManageStudentsPage"
             xmlns:components="clr-namespace:SFI.View.Components">
    <VerticalStackLayout>

        <Grid ColumnDefinitions="*, Auto">
            <components:LogoutButton Grid.Column="1"/>
            <components:GoBackButton  Grid.Column="0"/>
        </Grid>




        <Button
            Text="Lägg till elev"
            Clicked="OnAddStudentClicked"
            Margin="0,10" />





        <CollectionView x:Name="StudentsList"
                SelectionMode="Single"
                SelectionChanged="OnStudentSelected">
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Frame Padding="10" Margin="5" BorderColor="Gray">
                        <Label Text="{Binding Name}" FontSize="20"/>
                    </Frame>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>





    </VerticalStackLayout>
</ContentPage>
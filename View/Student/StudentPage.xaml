<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="SFI.View.Student.StudentPage"
             Title="Student sida"
             xmlns:components="clr-namespace:SFI.View.Components">
    <VerticalStackLayout>


        <Grid ColumnDefinitions="*, Auto">
            <components:LogoutButton Grid.Column="1"/>
        </Grid>
        
        <Button
             Text="Meddelande"
             WidthRequest="500"
             HeightRequest="40"
             BackgroundColor="DarkGray"
             HorizontalOptions="Center"
             VerticalOptions="Center"
             Margin="0,20,0,0"
             TextColor="Black"
             Clicked="OmMessageClicked" />

        <Button 
            Text="Vädret"
            WidthRequest="500"
            HeightRequest="40"
            BackgroundColor="BurlyWood"
            HorizontalOptions="Center"
            VerticalOptions="Center"
            Margin="0,10,0,0"
            TextColor="Black"
            Clicked="OnWeatherClicked"
        />



    </VerticalStackLayout>
</ContentPage>
<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="SFI.View.SendMessagePage"
             Title="SendMessagePage"
             xmlns:components="clr-namespace:SFI.View.Components">
    <VerticalStackLayout>

        <Grid ColumnDefinitions="*, Auto">
            <components:GoBackButton  Grid.Column="0"/>
        </Grid>


        <Label x:Name="RecipientLabel"
           Text="Mottagare"
           FontSize="18"
           Margin="0,0,0,20" />

        <Picker x:Name="RecipientPicker"
            Title="Välj mottagare"
            IsVisible="False"
            ItemDisplayBinding="{Binding Name}" />

        <Editor x:Name="MessageEntry"
            Placeholder="Skriv ditt meddelande här..."
            AutoSize="TextChanges"
            HeightRequest="170"
            Margin="0,20,0,0" />

        <Button Text="Skicka"
            Clicked="OnSendClicked"
            BackgroundColor="#4CAF50"
            TextColor="White"
            CornerRadius="10"
            HeightRequest="50"
            Margin="0,20,0,0" />

    </VerticalStackLayout>
</ContentPage>